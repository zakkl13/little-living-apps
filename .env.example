# little-living-apps configuration (Rust `lila` agent)
# Copy to .env and fill in. NEVER commit the real .env. Docker instances copy these values into
# .docker/<instance>.env; the legacy systemd bootstrap installs them as /etc/lila/<instance>.env.

# --- Required ---
# From @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Comma-separated Telegram user IDs allowed to use the bot (single owner).
# Get yours from @userinfobot.
ALLOWED_USER_IDS=11111111
# No API key is required: the manager and workers ride a SUBSCRIPTION (no metered plane). Which one
# depends on AGENT_BACKEND below — set the wrong backend's API key and the bot refuses to start.

# --- Agent backend ---
# Which subscription-billed backend powers the manager + workers: codex (default) | claude.
#   codex  → drives the `codex` CLI, ChatGPT subscription, auth via `codex login`,
#            NEVER set OPENAI_API_KEY / CODEX_API_KEY.
#   claude → drives the `claude` CLI, Claude Pro/Max subscription. Run `claude setup-token`,
#            then save the printed token here as CLAUDE_CODE_OAUTH_TOKEN. NEVER set
#            ANTHROPIC_API_KEY.
# AGENT_BACKEND=codex
# CLAUDE_CODE_OAUTH_TOKEN=
# Note: the in-chat `/backend codex|claude` command persists its choice under MANAGER_STATE_DIR and
# overrides this value from then on (until changed again via /backend). Delete that state to revert.

# --- Manager / workers (the agent models) ---
# Optional model overrides. Leave unset for the backend defaults:
#   codex  → CLI default for both.
#   claude → manager claude-opus-4-8 (xhigh), workers claude-sonnet-4-6.
# Codex example: MANAGER_MODEL=gpt-5-codex ; Claude example: MANAGER_MODEL=claude-opus-4-8
# MANAGER_MODEL=
# WORKER_MODEL=
# Manager reasoning effort: minimal | low | medium | high | xhigh (default xhigh).
# MANAGER_REASONING_EFFORT=xhigh
# Manager working directory (holds the generated AGENTS.md). Defaults to $MANAGER_STATE_DIR/manager.
# MANAGER_DIR=
# Manager memory repo (git markdown + sqlite FTS), exposed to the memory tools as /memories.
MEMORY_DIR=/var/lib/lila/memory
# Thread-id + queue + worker snapshots for cold-restart recovery (fresh schema; lossless restart).
MANAGER_STATE_DIR=/var/lib/lila/state

# --- Lila MCP server (the manager's only hands; in-process, loopback) ---
# The manager reaches its memory + subagent tools over a loopback streamable-HTTP MCP server.
# Optional: bind a fixed port (default: a free port is chosen each boot).
# LILA_MCP_PORT=8765
# Optional: bearer token for that server (default: auto-generated per boot). Loopback + token is
# defense in depth on a single-tenant host.
# LILA_MCP_TOKEN=

# --- Transport ---
# The bot talks to Telegram by OUTBOUND long-poll (getUpdates). It opens NO inbound port and needs
# no public URL or TLS, so it runs behind NAT, on a home box, or on a bare VM.

# --- Publishing the app (optional) ---
# The ONE domain knob. A bare host (no scheme). If set, the same URL is surfaced to the manager
# prompt as where the app is published. Docker can front it with the Caddy Compose profile; the
# legacy systemd bootstrap writes a host Caddy site block. Requires DNS pointed at this host and
# ports 80/443 reachable. Leave empty to keep the app private to the box.
# LILA_DOMAIN=app.example.com

# --- The app the agent builds + maintains ---
# The STACK decides the *kind of app* the team builds — a plugin under stacks/<name>/ (a stack.toml
# plus a scaffold script and two prompt fragments). Pick one per instance; the same value drives the
# scaffold, the serve command, the app toolchain, the agent prompts, and the eval fixture. Ships with
# `rails-pwa` (Rails 8 + PWA, the default) and `node-react` (a zero-build Node + React PWA). Drop in a
# new directory to add your own — no Rust changes, no recompile. Default: rails-pwa.
# LILA_STACK=rails-pwa
# The DESIGN system the app starts on (framework-universal — every app draws one, independent of the
# stack). `random` (default) draws blindly from a tiny pool of SAFE NEUTRALS, so a fresh app always
# looks designed but never catastrophic; the agent then offers to change it once a screen exists, and
# you can re-pick anytime. `random:<seed>` is a reproducible draw. `<brand>` pins a specific system from
# the Open Design catalog (any of the 150 — see design/systems/INDEX.md; bootstrap pulls the full set at
# standup), bypassing the draw + the offer. The look is locked per app and won't reroll on its own.
# Default: random.
# LILA_DESIGN=random
# Holds the single app the agent builds and maintains. A persistent git repo on the VM disk.
# Docker pins this to /workspace inside the app/manager containers. The legacy systemd path uses
# /srv/<instance>.
WORKSPACE_DIR=/srv/primary
# Port the app binds on 127.0.0.1 (the lila-app@ unit reads ${APP_PORT}; Caddy fronts it on your
# domain). bootstrap.sh wires the primary's Caddy site block to whatever you set here.
APP_PORT=3000
# Interface the app process binds inside its supervisor. systemd keeps this private to localhost;
# Docker Compose binds 0.0.0.0 inside the app container so Caddy/port publishing can reach it.
# APP_HOST=127.0.0.1
# URL workers use for browser/curl validation. systemd hosts use localhost; Docker Compose instances
# use the app service DNS name (`http://app:$APP_PORT`) inside the project network.
# LILA_APP_URL=http://localhost:3000
# Legacy systemd unit name. Docker instances use LILA_APP_RESTART_CMD instead.
# LILA_APP_SERVICE=lila-app@primary
# The supervisor-specific restart command workers run after structural app changes. On systemd hosts,
# bootstrap pins this to `sudo systemctl restart lila-app@<instance>`. Docker instances set it to
# `docker restart <instance>-app` in the generated .docker/<instance>.env file.
# LILA_APP_RESTART_CMD="sudo systemctl restart lila-app@primary"

# --- Docker deployment ---
# `bin/new-instance-docker <name>` writes .docker/<name>.env and runs docker compose with these
# values. A Compose project is one app instance; volumes are named with the instance prefix.
# COMPOSE_PROJECT_NAME=primary
# LILA_INSTANCE=primary
# LILA_ENV_FILE=.docker/primary.env
# LILA_IMAGE=lila-rs:dockerize
# Bind the app port on the host. Keep 127.0.0.1 when Caddy or another reverse proxy fronts it.
# APP_BIND=127.0.0.1

# --- Worker sandbox + Codex auth home ---
# Filesystem sandbox posture (Codex vocabulary, mirrored to the worker runner):
#   danger-full-access  -> no sandbox; full fs + network access (default; the VM IS the boundary)
#   workspace-write     -> writable workspace, restricted elsewhere
#   read-only           -> no writes
# The runner also runs headless (no approval prompts), since there is no one to approve.
CODEX_SANDBOX_MODE=danger-full-access
# Optional: absolute path to a specific codex binary. Leave unset to resolve `codex` from PATH.
# bootstrap.sh pins this automatically in /etc/lila/<instance>.env when it can resolve the mise CLI.
# It still reads CODEX_HOME for auth.
# CODEX_BIN=/usr/local/bin/codex
# Optional: absolute path to a specific claude binary. Leave unset to resolve `claude` from PATH.
# bootstrap.sh pins this automatically in /etc/lila/<instance>.env when it can resolve the mise CLI.
# CLAUDE_BIN=/usr/local/bin/claude
# $CODEX_HOME — where the ChatGPT-subscription auth lives (persists on the VM disk).
CODEX_HOME=/var/lib/lila/codex

# --- Inspector: read-only manager observability plane (off by default) ---
# A read-only HTTP view of the manager's conversation, token usage (manager vs worker, input /
# cached / output / reasoning), memories, worker prompts, and request→worker traces. It binds
# 127.0.0.1 only; Caddy fronts it at /_inspect (see deploy/Caddyfile). It is NEVER a model tool and
# never mutates state. There is no dollar meter — everything rides the subscription.
# INSPECTOR_ENABLED=true
# Port the Inspector binds on 127.0.0.1 (Caddy reverse-proxies /_inspect here).
# INSPECTOR_PORT=9090
# Shared secret required on every Inspector request (?t=... or x-inspector-token header). Strongly
# recommended whenever enabled — any long random string.
# INSPECTOR_TOKEN=

# --- Test / advanced ---
# Telegram Bot API base URL. Override in tests to point at a fake server.
TELEGRAM_API_BASE_URL=https://api.telegram.org

# --- MUST NOT be set ---
# Setting OPENAI_API_KEY or CODEX_API_KEY (codex) / ANTHROPIC_API_KEY (claude) flips the backend off
# its subscription to metered API billing. The bot REFUSES to start if the active backend's key is
# present — the last line between you and a surprise invoice.
# OPENAI_API_KEY=
# CODEX_API_KEY=
# ANTHROPIC_API_KEY=
