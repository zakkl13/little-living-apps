# sprite-codex-bot configuration (v0.2 — see DESIGN.md §10)
# Copy to .env and fill in. NEVER commit the real .env.

# --- Required ---
# From @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Comma-separated Telegram user IDs allowed to use the bot (single owner in v0.2).
# Get yours from @userinfobot.
ALLOWED_USER_IDS=11111111
# Shared secret verified against Telegram's X-Telegram-Bot-Api-Secret-Token header.
# Also used (by default) as the unguessable webhook path segment. Use a long random string.
TELEGRAM_WEBHOOK_SECRET=change-me-to-a-long-random-string
# The manager's brain (Claude). The ONLY paid/metered plane. Required.
ANTHROPIC_API_KEY=sk-ant-...

# --- Manager (Claude) ---
# Models (DESIGN §10). Manager leanness is the cost-control lever.
MANAGER_MODEL=claude-opus-4-8
UTILITY_MODEL=claude-haiku-4-5
# Manager memory repo (git markdown + sqlite FTS), exposed to the memory tool as /memories.
MEMORY_DIR=/workspace/.manager/memory
# Transcript + queue + worker snapshots for cold-wake recovery (DESIGN §11).
MANAGER_STATE_DIR=/workspace/.manager/state
# Optional: override the Anthropic base URL (tests point this at a fake; never needed in prod).
# ANTHROPIC_BASE_URL=

# --- Webhook server ---
# Port the bot listens on. On a Sprite this must be the routed HTTP port so inbound
# requests wake the box.
PORT=8080
# Public HTTPS base URL of the Sprite. If set, the bot calls setWebhook on startup so
# Telegram delivers updates here. Leave empty to register the webhook manually.
# Example: https://my-sprite.fly.dev
PUBLIC_URL=
# Optional explicit webhook path. Defaults to /tg/<TELEGRAM_WEBHOOK_SECRET>.
# WEBHOOK_PATH=/tg/change-me

# --- Workers (Codex via @openai/codex-sdk threads API) ---
# Holds project repos workers operate on. A persistent git repo on the Sprite volume.
WORKSPACE_DIR=/workspace/project
# Sandbox posture (SDK ThreadOptions.sandboxMode):
#   danger-full-access  -> no sandbox init at all; full fs + network access (default)
#   workspace-write     -> writable workspace, restricted elsewhere
#   read-only           -> no writes
# Default is "danger-full-access": the Sprite IS the isolation boundary, and Landlock/seccomp
# may not initialize inside a microVM, so we skip the in-process sandbox entirely. The runner
# also sets approvalPolicy "never" (headless — there is no one to approve prompts).
CODEX_SANDBOX_MODE=danger-full-access
# Optional: absolute path to a specific codex binary for the SDK to drive. Leave unset to use
# the SDK's bundled/resolved binary (it still reads CODEX_HOME for ChatGPT-subscription auth).
# CODEX_BIN=/usr/local/bin/codex
# $CODEX_HOME — keep on the persistent volume so auth survives hibernation.
CODEX_HOME=/workspace/.codex

# --- Test / advanced ---
# Telegram Bot API base URL. Override in tests to point at a fake server.
TELEGRAM_API_BASE_URL=https://api.telegram.org

# --- MUST NOT be set on the Sprite ---
# Setting OPENAI_API_KEY or CODEX_API_KEY flips Codex to metered API billing instead of the
# ChatGPT subscription (DESIGN §10). The bot refuses to start if either is present.
# OPENAI_API_KEY=
# CODEX_API_KEY=
