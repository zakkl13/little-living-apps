# little-living-apps configuration (v0.2 — see DESIGN.md §10)
# Copy to .env and fill in. NEVER commit the real .env.

# --- Required ---
# From @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Comma-separated Telegram user IDs allowed to use the bot (single owner in v0.2).
# Get yours from @userinfobot.
ALLOWED_USER_IDS=11111111
# The manager's brain (Claude). The ONLY paid/metered plane. Required.
ANTHROPIC_API_KEY=sk-ant-...

# --- Manager (Claude) ---
# Model (DESIGN §10). Manager leanness is the cost-control lever.
MANAGER_MODEL=claude-opus-4-8
# Manager memory repo (git markdown + sqlite FTS), exposed to the memory tool as /memories.
MEMORY_DIR=/var/lib/lila/memory
# Transcript + queue + worker snapshots for cold-restart recovery (DESIGN §11).
MANAGER_STATE_DIR=/var/lib/lila/state
# Optional: override the Anthropic base URL (tests point this at a fake; never needed in prod).
# ANTHROPIC_BASE_URL=

# --- Transport ---
# The bot talks to Telegram by OUTBOUND long-poll (getUpdates). It opens NO inbound port and
# needs no public URL or TLS, so it runs behind NAT, on a home box, or on a bare VM.
# Optional: where the app the agent builds is served, surfaced to the manager prompt. Leave empty
# until you deliberately publish the app (it is private by default). Example: https://app.example.com
APP_PUBLIC_URL=

# --- Publishing the app (optional) ---
# Domain to serve the app on. If set, bootstrap.sh installs + configures Caddy (auto-HTTPS) to
# reverse-proxy https://$LILA_DOMAIN -> the app on 127.0.0.1:3000. Requires DNS pointed at this host
# and ports 80/443 reachable. Leave empty to keep the app private to the box.
# LILA_DOMAIN=app.example.com

# --- Workers (Codex via @openai/codex-sdk threads API) ---
# Holds the single app the agent builds and maintains. A persistent git repo on the VM disk.
WORKSPACE_DIR=/srv/app
# Sandbox posture (SDK ThreadOptions.sandboxMode):
#   danger-full-access  -> no sandbox init at all; full fs + network access (default)
#   workspace-write     -> writable workspace, restricted elsewhere
#   read-only           -> no writes
# Default is "danger-full-access": the disposable VM IS the isolation boundary, so we skip the
# in-process sandbox entirely. The runner also sets approvalPolicy "never" (headless — there is no
# one to approve prompts).
CODEX_SANDBOX_MODE=danger-full-access
# Optional: absolute path to a specific codex binary for the SDK to drive. Leave unset to use
# the SDK's bundled/resolved binary (it still reads CODEX_HOME for ChatGPT-subscription auth).
# CODEX_BIN=/usr/local/bin/codex
# $CODEX_HOME — where the ChatGPT-subscription auth lives (persists on the VM disk).
CODEX_HOME=/var/lib/lila/codex

# --- Test / advanced ---
# Telegram Bot API base URL. Override in tests to point at a fake server.
TELEGRAM_API_BASE_URL=https://api.telegram.org

# --- MUST NOT be set ---
# Setting OPENAI_API_KEY or CODEX_API_KEY flips Codex to metered API billing instead of the
# ChatGPT subscription (DESIGN §10). The bot refuses to start if either is present.
# OPENAI_API_KEY=
# CODEX_API_KEY=
