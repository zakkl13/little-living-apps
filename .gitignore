/target

# macOS Finder metadata
.DS_Store

# llvm-cov coverage artifacts (scripts/coverage.sh) — profile data + generated badge JSON
*.profraw
/coverage.json

# Eval run artifacts (per-trial transcripts + reports)
/eval/results/
# The Rails fixture's vendored gems are built locally by eval/fixtures/setup-rails.sh (78MB), not committed
/eval/fixtures/rails-app/vendor/bundle/
/eval/fixtures/rails-app/.bundle/
/eval/fixtures/rails-app/log/
/eval/fixtures/rails-app/tmp/
/eval/fixtures/rails-app/storage/*.sqlite3*

# Private dogfooding/operations setup for the live host (instance ids, tokens, deploy scripts,
# RUNBOOK, parked env secrets). Local-only — never part of the OSS framework.
/dogfooding/

# Intermediate planning artifacts from working sessions. Local-only scratch.
/claude-plans/

# Hero-video staging workspace (Remotion project + node_modules + raw captures). The finished
# assets live in /docs and are committed; the staging tree is local-only (~510MB).
/video-assets-staging/
/video-assets-boxes/

# Open Design catalog (~12MB of per-brand packages). Only the safety-net subset is committed — the
# default-pool neutrals + stripe — so a blind `random` draw and the tests work offline with zero
# fetch. The rest of the 150-system catalog is pulled at standup by bin/fetch-design-catalog (see
# design/systems/PROVENANCE). INDEX.md / PROVENANCE / LICENSE.upstream stay tracked (lila's curation).
/design/systems/*/
!/design/systems/default/
!/design/systems/friendly/
!/design/systems/warm-editorial/
!/design/systems/stripe/
