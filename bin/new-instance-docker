#!/usr/bin/env bash
# Stand up one little-living-apps instance with Docker Compose.
#
# This is the Docker analogue of bin/new-instance: one Compose project per app instance, with
# instance-prefixed named volumes and a generated .env file under .docker/.
set -euo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

log() { printf '\033[1;36m[new-instance-docker]\033[0m %s\n' "$*"; }
die() { echo "ERROR: $*" >&2; exit 1; }

NAME="${1:-}"
[[ -n "$NAME" ]] || die "Usage: [TELEGRAM_BOT_TOKEN=... ALLOWED_USER_IDS=...] bin/new-instance-docker <name>"
[[ "$NAME" =~ ^[a-z0-9][a-z0-9-]*$ ]] || die "Instance name must be lowercase alnum/dash (got '$NAME')."

command -v docker >/dev/null 2>&1 || die "docker is not installed or not on PATH."
docker compose version >/dev/null 2>&1 || die "docker compose is not available."

read_env_file() {
  local key="$1" file="$2"
  [[ -f "$file" ]] || return 0
  grep -E "^${key}=" "$file" | tail -1 | cut -d= -f2- | sed -E 's/^"//; s/"$//; s/^'\''//; s/'\''$//' || true
}

inherit() {
  local key="$1" fallback_file="$2"
  [[ -n "${!key:-}" ]] && return 0
  local value
  value="$(read_env_file "$key" "$fallback_file")"
  [[ -n "$value" ]] && printf -v "$key" '%s' "$value" || true
}

SOURCE_ENV="${SOURCE_ENV:-$REPO_DIR/.env}"
inherit TELEGRAM_BOT_TOKEN "$SOURCE_ENV"
inherit ALLOWED_USER_IDS "$SOURCE_ENV"
inherit AGENT_BACKEND "$SOURCE_ENV"
inherit CLAUDE_CODE_OAUTH_TOKEN "$SOURCE_ENV"
inherit LILA_STACK "$SOURCE_ENV"
inherit LILA_DESIGN "$SOURCE_ENV"
inherit LILA_DOMAIN "$SOURCE_ENV"
inherit INSPECTOR_TOKEN "$SOURCE_ENV"

[[ -n "${TELEGRAM_BOT_TOKEN:-}" ]] || die "TELEGRAM_BOT_TOKEN is required."
[[ -n "${ALLOWED_USER_IDS:-}" ]] || die "ALLOWED_USER_IDS is required."

AGENT_BACKEND="${AGENT_BACKEND:-codex}"
LILA_STACK="${LILA_STACK:-rails-pwa}"
LILA_DESIGN="${LILA_DESIGN:-random}"
APP_PORT="${APP_PORT:-3000}"
INSPECTOR_PORT="${INSPECTOR_PORT:-9090}"
APP_BIND="${APP_BIND:-127.0.0.1}"
LILA_IMAGE="${LILA_IMAGE:-lila-rs:dockerize}"
ENV_DIR="$REPO_DIR/.docker"
ENV_FILE="$ENV_DIR/$NAME.env"
REL_ENV_FILE=".docker/$NAME.env"

case "$AGENT_BACKEND" in
  codex)
    for key in OPENAI_API_KEY CODEX_API_KEY; do
      [[ -z "${!key:-}" ]] || die "$key is set; unset it so Codex stays on subscription auth."
    done
    ;;
  claude)
    [[ -z "${ANTHROPIC_API_KEY:-}" ]] || die "ANTHROPIC_API_KEY is set; unset it so Claude stays on subscription auth."
    ;;
  *)
    die "AGENT_BACKEND must be codex or claude (got '$AGENT_BACKEND')."
    ;;
esac

mkdir -p "$ENV_DIR"
umask 077
cat > "$ENV_FILE" <<EOF
# Generated by bin/new-instance-docker for instance '$NAME'.
COMPOSE_PROJECT_NAME=$NAME
LILA_INSTANCE=$NAME
LILA_ENV_FILE=$REL_ENV_FILE
LILA_IMAGE=$LILA_IMAGE

TELEGRAM_BOT_TOKEN=$TELEGRAM_BOT_TOKEN
ALLOWED_USER_IDS=$ALLOWED_USER_IDS
AGENT_BACKEND=$AGENT_BACKEND
CLAUDE_CODE_OAUTH_TOKEN=${CLAUDE_CODE_OAUTH_TOKEN:-}

LILA_STACK=$LILA_STACK
LILA_DESIGN=$LILA_DESIGN
LILA_DOMAIN=${LILA_DOMAIN:-}
APP_PORT=$APP_PORT
APP_HOST=0.0.0.0
APP_BIND=$APP_BIND
INSPECTOR_ENABLED=${INSPECTOR_ENABLED:-true}
INSPECTOR_PORT=$INSPECTOR_PORT
INSPECTOR_TOKEN=${INSPECTOR_TOKEN:-}

WORKSPACE_DIR=/workspace
MEMORY_DIR=/var/lib/lila/memory
MANAGER_STATE_DIR=/var/lib/lila/state
CODEX_HOME=/var/lib/lila/codex
CODEX_SANDBOX_MODE=${CODEX_SANDBOX_MODE:-danger-full-access}
LILA_APP_RESTART_CMD="${LILA_APP_RESTART_CMD:-docker restart ${NAME}-app}"
LILA_APP_URL=http://app:$APP_PORT
TELEGRAM_API_BASE_URL=${TELEGRAM_API_BASE_URL:-https://api.telegram.org}
EOF
chmod 600 "$ENV_FILE"
umask 022

log "Creating named volumes for '$NAME'"
for suffix in workspace memory state codex-home caddy-data caddy-config; do
  docker volume create "$NAME-$suffix" >/dev/null
done

log "Starting Compose project '$NAME'"
COMPOSE_PROJECT_NAME="$NAME" docker compose \
  --env-file "$ENV_FILE" \
  -f "$REPO_DIR/compose.yaml" \
  up -d --build

cat <<EOF

Instance '$NAME' is running under Docker Compose.

Env file:  $ENV_FILE
App:       http://$APP_BIND:$APP_PORT
Logs:      COMPOSE_PROJECT_NAME=$NAME docker compose --env-file $ENV_FILE -f $REPO_DIR/compose.yaml logs -f

For Codex auth, run:
  COMPOSE_PROJECT_NAME=$NAME docker compose --env-file $ENV_FILE -f $REPO_DIR/compose.yaml exec manager codex login --device-auth
  COMPOSE_PROJECT_NAME=$NAME docker compose --env-file $ENV_FILE -f $REPO_DIR/compose.yaml restart manager
EOF
