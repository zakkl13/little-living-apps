#!/usr/bin/env bash
# bin/new-app — scaffold ONE instance's app and run it under systemd. STACK-GENERIC: this script owns
# the framework contract (instance dir /srv/<instance>, env file, service user, systemd install/start)
# and delegates the app-creation body to the ACTIVE STACK's scaffold script. The stack
# (stacks/<name>/) decides the kind of app — Rails 8 + PWA by default, Node + React, or any directory
# you drop in — with zero changes here. The serve command + environment come from the stack's
# stack.toml, read via `lila stack`.
#
# Always runs in INSTANCE mode: every app — including the primary — is a systemd template instance
# lila-app@<instance> serving /srv/<instance> and reading /etc/lila/<instance>.env. The caller sets
# LILA_INSTANCE (bootstrap.sh → "primary"; bin/new-instance → the new name; the lila-new-app wrapper
# forwards the running manager's instance).
#
#   sudo LILA_INSTANCE=primary bash bin/new-app                 # scaffold + install + start lila-app@primary
#   sudo LILA_INSTANCE=… LILA_STACK=node-react bash bin/new-app # a different stack for this instance
#   SKIP_AUTH=1 sudo LILA_INSTANCE=… bash bin/new-app           # skip a stack's optional auth step
#
# Idempotent: if the app is already scaffolded the stack's scaffold.sh no-ops and we only
# re-install/start the service.
set -euo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

log() { printf '\033[1;35m[new-app]\033[0m %s\n' "$*"; }
die() { echo "ERROR: $*" >&2; exit 1; }

[[ $EUID -eq 0 ]] || die "Run with sudo (needs systemd): sudo bash bin/new-app"

SERVICE_USER="${SERVICE_USER:-${SUDO_USER:-}}"
[[ -n "$SERVICE_USER" && "$SERVICE_USER" != "root" ]] ||
  die "Could not determine a non-root service user. Re-run via sudo from your normal account, or set SERVICE_USER=<name>."
USER_HOME="$(getent passwd "$SERVICE_USER" | cut -d: -f6)"
MISE="$USER_HOME/.local/bin/mise"
[[ -x "$MISE" ]] || die "mise not found at $MISE — run bootstrap.sh first."

# Which instance's app: fixes the app dir (/srv/<instance>) and the systemd template unit
# (lila-app@<instance>). Required — there is no non-instance fallback.
INSTANCE="${LILA_INSTANCE:-}"
[[ -n "$INSTANCE" ]] ||
  die "LILA_INSTANCE is not set. Run via bootstrap.sh / bin/new-instance, or the lila-new-app wrapper (which forwards the manager's instance)."
INSTANCE_ENV="/etc/lila/$INSTANCE.env"
APP_DIR="${WORKSPACE_DIR:-/srv/$INSTANCE}"
# APP_PORT is cosmetic here (the template unit reads ${APP_PORT} from the env file); source it from the
# instance's env file when present so the log/heredoc report the real port, else fall back to 3000.
# Tolerant: a missing key (grep finds nothing) must yield empty, not a non-zero exit that `set -e`
# would turn into a hard abort — instance env files legitimately omit optional keys (e.g. LILA_DESIGN).
read_env() { grep -E "^$1=" "$INSTANCE_ENV" 2>/dev/null | cut -d= -f2- | tr -d '"'\''' || true ; }
APP_PORT="${APP_PORT:-$(read_env APP_PORT)}"
APP_PORT="${APP_PORT:-3000}"
DOMAIN="${LILA_DOMAIN:-$(read_env LILA_DOMAIN)}"

# The active stack for this instance: explicit env wins, else the instance's env file, else the
# framework default. Resolve its contract via the compiled binary (no TOML parsing in bash).
LILA_STACK="${LILA_STACK:-$(read_env LILA_STACK)}"
LILA_STACK="${LILA_STACK:-rails-pwa}"
# The active design choice (safe blind draw by default). Resolved against the vendored catalog below,
# only if the stack opts into the design system.
LILA_DESIGN="${LILA_DESIGN:-$(read_env LILA_DESIGN)}"
LILA_DESIGN="${LILA_DESIGN:-random}"
LILA_BIN="${LILA_BIN:-/opt/lila/bin/lila}"
[[ -x "$LILA_BIN" ]] || LILA_BIN="$REPO_DIR/target/release/lila"
[[ -x "$LILA_BIN" ]] || LILA_BIN="$REPO_DIR/target/debug/lila"
[[ -x "$LILA_BIN" ]] || die "lila binary not found (looked in /opt/lila/bin and $REPO_DIR/target/*) — run bootstrap.sh first."

# `lila stack` resolves stacks/ from its CWD, so query it from the repo root. Exports LILA_STACK_*.
log "Active stack: $LILA_STACK"
eval "$(cd "$REPO_DIR" && "$LILA_BIN" stack "$LILA_STACK")" ||
  die "Unknown stack '$LILA_STACK' (expected a directory under $REPO_DIR/stacks/)."
[[ -f "$LILA_STACK_SCAFFOLD" ]] || die "Stack '$LILA_STACK' scaffold script missing: $LILA_STACK_SCAFFOLD"

# --- 0b. Draw a design system ------------------------------------------------------------------
# Design is framework-generic, not a per-stack opt-in: every instance draws one. A blind `random` is
# bounded to the safe default pool by `lila design draw`; a `<brand>` pin reaches any system. The chosen
# system + its package dir are exported into the scaffold env so a stack that renders UI turns it into
# real tokens and writes design.lock; a stack whose scaffold ignores it simply doesn't.
LILA_DESIGN_BRAND='' LILA_DESIGN_FILE='' LILA_DESIGN_DIR='' LILA_DESIGN_POOL='' LILA_DESIGN_SOURCE='' LILA_DESIGN_SEED='' LILA_DESIGN_COMMIT=''
log "Drawing a design system (LILA_DESIGN=$LILA_DESIGN)"
eval "$(cd "$REPO_DIR" && "$LILA_BIN" design draw "$LILA_DESIGN")" ||
  die "Could not resolve LILA_DESIGN='$LILA_DESIGN' against the catalog."
log "Active design: $LILA_DESIGN_BRAND (pool=$LILA_DESIGN_POOL, source=$LILA_DESIGN_SOURCE)"

# --- 1. Scaffold the app (delegated to the active stack) ---------------------------------------
# Run the stack's scaffold body as the service user, in the app dir, with the framework's variables in
# the environment. The stack owns everything app-specific (install steps, generators, post-tweaks).
# The LILA_DESIGN_* draw + LILA_BIN are passed through so a stack's render can copy the system's curated
# tokens.css + reference package (LILA_DESIGN_DIR) and write design.lock.
# Put mise on PATH for scaffold-time hooks such as RubyGems' `mise reshim`.
log "Scaffolding the app via $LILA_STACK scaffold ($APP_DIR)"
( cd "$APP_DIR" && sudo -u "$SERVICE_USER" -H \
    env PATH="$USER_HOME/.local/bin:$PATH" \
        LILA_INSTANCE="$INSTANCE" APP_DIR="$APP_DIR" APP_PORT="$APP_PORT" \
        LILA_DOMAIN="$DOMAIN" SKIP_AUTH="${SKIP_AUTH:-}" \
        SERVICE_USER="$SERVICE_USER" MISE="$MISE" LILA_BIN="$LILA_BIN" \
        LILA_DESIGN_BRAND="$LILA_DESIGN_BRAND" LILA_DESIGN_FILE="$LILA_DESIGN_FILE" \
        LILA_DESIGN_DIR="$LILA_DESIGN_DIR" \
        LILA_DESIGN_POOL="$LILA_DESIGN_POOL" LILA_DESIGN_SOURCE="$LILA_DESIGN_SOURCE" \
        LILA_DESIGN_SEED="$LILA_DESIGN_SEED" LILA_DESIGN_COMMIT="$LILA_DESIGN_COMMIT" \
    bash "$LILA_STACK_SCAFFOLD" )

# --- 2. Install + start the app service ---------------------------------------------------------
# Template unit: host-level constants (__USER__/__MISE__) and the stack's serve command (__EXEC__) +
# environment (__ENV__) are substituted once; %i selects the dir (/srv/%i) and env file
# (/etc/lila/%i.env, which carries APP_PORT). Safe to re-install (idempotent).
APP_UNIT="lila-app@$INSTANCE"
# Build the systemd `Environment=` block from the stack's serve env (one line per K=V, possibly none).
ENV_BLOCK=""
while IFS= read -r kv; do
  [[ -n "$kv" ]] && ENV_BLOCK+="Environment=$kv"$'\n'
done <<< "$LILA_STACK_SERVE_ENV"
ENV_BLOCK="${ENV_BLOCK%$'\n'}"   # drop the trailing newline so no blank line is left in the unit

log "Installing systemd template unit lila-app@.service; starting $APP_UNIT (127.0.0.1:$APP_PORT)"
sed -e "s|__USER__|$SERVICE_USER|g" -e "s|__MISE__|$MISE|g" \
  "$REPO_DIR/deploy/lila-app@.service" \
  | awk -v env="$ENV_BLOCK" -v exec_line="$LILA_STACK_SERVE_EXEC" '
      { gsub(/__ENV__/, env); gsub(/__EXEC__/, exec_line); print }' \
  > /etc/systemd/system/lila-app@.service
systemctl daemon-reload
systemctl enable "$APP_UNIT"
systemctl restart "$APP_UNIT"

cat <<EOF

────────────────────────────────────────────────────────────────────────────
App ($LILA_STACK_DISPLAY) is live on http://127.0.0.1:$APP_PORT (private to the box).
  Logs:    journalctl -u $APP_UNIT -f
  Restart: sudo systemctl restart $APP_UNIT   # for new dependencies / config / routes / migrations

To publish it behind YOUR domain (TLS via Caddy):
  1. Point your domain's DNS at this host.
  2. Set LILA_DOMAIN and re-run bootstrap.sh (primary) or bin/new-instance (added apps): each writes
     this instance's Caddy site block at /etc/caddy/sites/$INSTANCE.caddy and installs Caddy for you.
────────────────────────────────────────────────────────────────────────────
EOF
