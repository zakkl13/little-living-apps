{
  "name": "sprite-codex-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Telegram bot bridging to a headless OpenAI Codex session running on a Fly Sprite",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json",
    "test": "tsx --test \"test/**/*.test.ts\""
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@openai/codex-sdk": "^0.137.0"
  }
}
