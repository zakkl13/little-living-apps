<%#
  Empty state — always show a real one instead of a blank screen. Usage:
    <%= render "components/empty_state", title: "No books yet", body: "Add your first read to get started." %>
%>
<div class="empty-state">
  <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" style="width:2rem;height:2rem;">
    <path d="M4 5h16v14H4z"></path><path d="M4 9h16"></path>
  </svg>
  <h3><%= title %></h3>
  <% if local_assigns[:body] %><p style="margin-inline:auto;"><%= body %></p><% end %>
  <% if local_assigns[:action_label] && local_assigns[:action_href] %>
    <%= render "components/button", label: action_label, href: action_href, variant: "primary" %>
  <% end %>
</div>
