<%#
  Button in the locked design system. Usage:
    <%= render "components/button", label: "Save", variant: "primary" %>
    <%= render "components/button", label: "Cancel", href: root_path, variant: "secondary" %>
  variant ∈ primary | secondary | ghost (default: primary). Pass `href` for a link-styled button.
%>
<% variant ||= "primary" %>
<% klass = "btn btn-#{variant}" %>
<% if local_assigns[:href] %>
  <%= link_to label, href, class: klass %>
<% else %>
  <%= button_tag label, type: (local_assigns[:type] || "submit"), class: klass %>
<% end %>
