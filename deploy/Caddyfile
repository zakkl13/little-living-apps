# Caddy reverse proxy for the app, with automatic HTTPS (Let's Encrypt) for your domain.
# The app the agent builds binds to 127.0.0.1:3000; Caddy fronts it on your domain and terminates
# TLS. The bot itself needs none of this — it talks to Telegram outbound — so Caddy is only for
# publishing the app.
#
# Usage:
#   1. Point your domain's DNS A/AAAA record at this host.
#   2. Install Caddy (https://caddyserver.com/docs/install), e.g. on Debian/Ubuntu via the apt repo.
#   3. Set your domain and run it:
#        sudo LILA_DOMAIN=app.example.com caddy run --config deploy/Caddyfile
#      (or copy to /etc/caddy/Caddyfile and `sudo systemctl enable --now caddy`).
#
# Access control is the app's job: generate Rails' built-in auth (bin/rails generate authentication)
# so only you + invited users get in. Caddy just publishes; it does not authenticate.
#
# MULTIPLE INSTANCES: this file publishes the PRIMARY app ($LILA_DOMAIN). Each additional instance
# (bin/new-instance) drops its own site block at /etc/caddy/sites/<name>.caddy, imported below — so a
# Caddyfile regen (which rewrites only this block) never clobbers the other instances. A glob that
# matches nothing is fine; bin/new-instance creates the directory.
import /etc/caddy/sites/*.caddy

{$LILA_DOMAIN:localhost} {
	# Inspector: the manager's read-only observability plane. Only routed when the manager is started
	# with INSPECTOR_ENABLED=true (it binds 127.0.0.1:9090). The manager checks INSPECTOR_TOKEN on
	# every request; uncomment basic_auth below for a second factor. handle_path strips the /_inspect
	# prefix, so the inspector server sees plain /, /api/*. Visit https://your-domain/_inspect/?t=TOKEN
	handle_path /_inspect/* {
		# basic_auth { you JDJhJDE0... }   # optional: generate the hash with `caddy hash-password`
		reverse_proxy 127.0.0.1:9090
	}

	reverse_proxy 127.0.0.1:3000
}
