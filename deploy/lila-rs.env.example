# /etc/lila/lila-rs.env — environment for the Rust manager on the cutover host.
# Reuses the TS values where they map (bot token, allowed users, backend, inspector token); the
# memory/state dirs are FRESH (clean-slate cutover). Values marked <FROM DISCOVERY> are filled from
# deploy/discover.sh output before install. Token/key lines are stripped by the binary's billing
# guard for any spawned CLI; never set OPENAI_API_KEY/ANTHROPIC_API_KEY here.

# --- identity / transport (same as the TS manager) ---
TELEGRAM_BOT_TOKEN=<FROM DISCOVERY: copy from /etc/lila/lila.env>
ALLOWED_USER_IDS=<FROM DISCOVERY: copy from /etc/lila/lila.env>

# --- backend (subscription only; no API keys) ---
AGENT_BACKEND=codex
CODEX_SANDBOX_MODE=workspace-write
# CODEX_HOME for worker/manager auth is inherited from the unit's User (ubuntu) + HOME, same as TS.

# --- the app the manager maintains: point at the SAME workspace so lillivinapps keeps being served ---
WORKSPACE_DIR=<FROM DISCOVERY: the existing manager workspace holding the Rails app>
LILA_DOMAIN=lillivinapps.zakk.io
# LILA_APP_SERVICE=<FROM DISCOVERY: the puma/app systemd unit the manager restarts, if any>

# --- memory + state: FRESH on cutover (Rust uses new schemas; does not read the TS snapshot) ---
MEMORY_DIR=/var/lib/lila-rs/memory
MANAGER_STATE_DIR=/var/lib/lila-rs/state

# --- Lila MCP server (manager's only tools; loopback, bearer-guarded) ---
LILA_MCP_PORT=8765
LILA_MCP_TOKEN=<generate: openssl rand -hex 24>

# --- Inspector: port 9090 matches the existing Caddy /_inspect proxy (no Caddy change needed) ---
INSPECTOR_ENABLED=1
INSPECTOR_PORT=9090
INSPECTOR_TOKEN=<FROM DISCOVERY: reuse INSPECTOR_TOKEN from dogfooding/host.env or rotate>
